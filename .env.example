# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spacebio

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
COHERE_API_KEY=...

# App
LOG_LEVEL=INFO
ENV=development

# --- Security / cost controls (all optional) ---

# API-key auth for the expensive analyze/retrieve/kb endpoints.
# Comma-separated list of accepted keys. Leave EMPTY/unset to DISABLE auth
# (default) — convenient for local dev and tests. When set, requests must send
# either an `X-API-Key: <key>` header or `Authorization: Bearer <key>`.
# API_KEY=

# Process-wide cap on concurrent five-agent analyses. Requests beyond this
# limit get HTTP 429 (no unbounded queueing). Default: 4.
# MAX_CONCURRENT_ANALYSES=4

# CORS allowed origins (comma-separated). Default targets local Next.js dev.
# Never use "*".
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
